# Cortex AI Agent — API Keys Template
# Copy this file to .env and fill in your keys
# All keys are optional - configure only the providers you want to use

# ============================================================================
# PRIMARY PROVIDERS
# ============================================================================

# Mistral AI — PRIMARY provider (recommended for general use)
# Get from: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# DeepSeek — V4 models with 1M context (V4-Pro, V4-Flash)
# Get from: https://api.xiaomimimo.com/v1/chat/completions
DEEPSEEK_API_KEY=
# DeepSeek output cap per response (max_tokens), tune by workload:
#   8192  = small/simple tasks (faster)
#   16384 = balanced default
#   32768 = large coding/refactor tasks
CORTEX_DEEPSEEK_MAX_OUTPUT_TOKENS=32768

OPENROUTER_API_KEY=
DASHSCOPE_API_KEY=


# Xiaomi MiMo — V2.5 family (1M ctx, MoE, agentic coding)
# API:  https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_KEY=tp-srano640s2o9xjoy8uiluikru1uhzij4j9hkfymnh5hijzuj
# MiMo timeouts — increase for large-context agentic tasks (defaults: connect=20s, read=40s, tool_read=50s)
CORTEX_MIMO_READ_TIMEOUT_SEC=120
CORTEX_MIMO_TOOL_READ_TIMEOUT_SEC=120


# OpenAI — GPT-4, GPT-4o, o1, o3 models
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — Claude 3.5/4 Sonnet, Opus, Haiku
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ============================================================================
# VISION & SPECIALIZED PROVIDERS
# ============================================================================

# SiliconFlow — Vision models (Qwen-VL, etc.)
# Get from: https://cloud.siliconflow.cn/
SILICONFLOW_API_KEY=

# Google Gemini — Gemini Pro/Flash models
# Get from: https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-api-key-here

# ============================================================================
# CLOUD PROVIDERS (AWS/GCP/Azure)
# ============================================================================

# AWS Bedrock — Claude via AWS
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-token

# Google Vertex AI
# GOOGLE_APPLICATION_CREDENTIALS=path-to-service-account.json
# CLOUD_ML_REGION=us-east5

# Azure Foundry
# ANTHROPIC_FOUNDRY_API_KEY=your-foundry-key

# ============================================================================
# ALTERNATIVE PROVIDERS
# ============================================================================

# Groq — Fast inference (Llama, Mixtral)
# GROQ_API_KEY=your-groq-api-key-here

# Together AI
# TOGETHER_API_KEY=your-together-api-key-here

# Qwen/Alibaba
# QWEN_API_KEY=your-qwen-api-key-here

# Kimi/Moonshot AI — K2.6 multimodal model (256k context, code, vision)
# Get from: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# XAI (Grok)
# XAI_API_KEY=your-xai-api-key-here

# ============================================================================
# CORTEX-SPECIFIC SETTINGS
# ============================================================================

# Web Search Providers
# SerpAPI — Google search results (100 free searches/month)
# Get from: https://serpapi.com/users/welcome
SERPAPI_API_KEY=
# Brave Search — Web search fallback (2,000 free queries/month)
# Get from: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-api-key-here

# Cortex Cloud Authentication (logic-practice.com)
# CORTEX_ID=your-cortex-id

# API Key Helper (custom command to retrieve keys dynamically)
# CORTEX_API_KEY_HELPER_TTL_MS=300000

# If no API keys are set, the app uses Mock mode (no real AI, but fully functional UI)

DASHSCOPE_BASE_URL=
