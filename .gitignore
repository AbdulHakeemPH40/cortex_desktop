# ============================================================================
# SENSITIVE FILES - NEVER COMMIT TO GIT
# ============================================================================

# Environment variables with API keys (CRITICAL - contains secrets!)
.env
.env.local
.env.production
.env.development
*.env

# Exception: Allow .env.example template (contains only placeholders)
!.env.example

# .env.example2 — contains real API keys, never commit
.env.example2

